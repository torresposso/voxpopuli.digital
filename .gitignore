web/app/cache/*

# Exports / dumps
/exports/*

# WordPress
web/wp
web/.htaccess

# Logs
*.log

# Dotenv
.env
.env.*
!.env.example

# Composer
/vendor
auth.json

# PHPUnit/Pest
phpunit.xml
.phpunit.result.cache
.phpunit.cache

# WP-CLI
wp-cli.local.yml

# Storage (database outside web root)
/storage/

# Development artifacts & temporary files
composer-setup.php
missing-batch-*.json
*.xml

# Node dependencies
/node_modules

# Agent skills (ignored per user request)
.agents/skills/
