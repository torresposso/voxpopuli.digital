{
  "name": "voxpopuli/vox-caribe",
  "type": "wordpress-theme",
  "license": "MIT",
  "description": "Vox Caribe — Homepage editorial tipo The Atlantic con identidad VoxPopuli.",
  "homepage": "https://voxpopuli.digital",
  "authors": [
    {
      "name": "VoxPopuli Digital"
    }
  ],
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "require": {
    "php": ">=8.3",
    "roots/acorn": "^6.0"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "post-autoload-dump": [
      "Roots\\Acorn\\ComposerScripts::postAutoloadDump"
    ]
  }
}
